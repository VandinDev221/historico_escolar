# Copie para .env na pasta backend:  cp env.sample .env  (Windows: copy env.sample .env)
# Este ficheiro é versionado; .env e .env.example não vão para o Git.

# Database (PostgreSQL)
# Prisma exige DATABASE_URL e DATABASE_URL_UNPOOLED (directUrl no schema). Em Postgres local sem pooler,
# use a mesma URL nas duas linhas — não muda o comportamento, só satisfaz o CLI.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/armazena_historico"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/armazena_historico"
#
# Neon na Render (https://console.neon.tech) — duas strings diferentes:
# DATABASE_URL = pooled ("-pooler"); DATABASE_URL_UNPOOLED = direct (sem "-pooler").
# ?sslmode=require&connect_timeout=30 nas duas ajuda cold start e TLS.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
# DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
#
# Na Render: defina as duas em Environment (Blueprint sync: false). Doc: https://www.prisma.io/docs/orm/overview/databases/neon
# Se `migrate deploy` falhar com P1002 (advisory lock), o render.yaml define PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1;
# em serviços criados antes do blueprint, adicione essa variável manualmente no painel (só um deploy de cada vez).
#
# Postgres na Render sem pooler: as duas variáveis podem ser iguais à mesma connection string.

# JWT
JWT_SECRET="sua-chave-secreta-muito-segura-aqui"
JWT_EXPIRES_IN="7d"

# Redis (opcional para cache)
REDIS_URL="redis://localhost:6379"

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGIN="http://localhost:3000"

# Rate limiting (por IP) - valores em milissegundos
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
RATE_LIMIT_BLOCK_DURATION_MS=0

# Proxy/HTTPS: em produção, sirva a API atrás de proxy reverso (Nginx, Caddy, etc.) com HTTPS
# e defina TRUST_PROXY=true para que req.ip reflita o IP real do cliente (rate limit correto).
TRUST_PROXY=false

# Porta da API
PORT=3001

# URL pública do frontend (para links de validação de declarações)
APP_PUBLIC_URL=http://localhost:3000

# Integração INEP / APIs governamentais (opcional)
INEP_API_URL=https://api-publica.inep.gov.br
INEP_API_KEY=

# Produção: desativa rotas /api/dev/* (logs, blocklist). Use true ou NODE_ENV=production
DISABLE_DEV_ROUTES=false

# --- Migração falhou no Neon (P3009 / P3018)? ---
# 1) No .env (não no env.sample), defina DATABASE_URL e DATABASE_URL_UNPOOLED com as URIs do Neon.
# 2) No PowerShell, pasta já deve ser ...\armazena_historico\backend — NÃO rode "cd backend" de novo.
# 3) Comandos:
#    npx prisma migrate resolve --rolled-back "20260306040514_add_atestado_image_url"
#    npx prisma migrate deploy
# Alternativa sem editar .env: $env:DATABASE_URL="..."; $env:DATABASE_URL_UNPOOLED="..."
