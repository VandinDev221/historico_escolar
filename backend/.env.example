# Database (PostgreSQL)
# Desenvolvimento (Docker local):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/armazena_historico"
#
# Produção — Neon (https://console.neon.tech):
# Cole a connection string do console. Inclua SSL, ex.:
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
#
# Na Render com Neon: use a mesma URI em Environment → DATABASE_URL.
# Preferência: no Neon, use o modo "Direct" (host sem "-pooler") para `prisma migrate deploy` funcionar sem surpresas.
# Se usar só URL "Pooled" (-pooler), configure também DIRECT_URL (Direct) e o bloco `directUrl` no schema.prisma — ver:
# https://www.prisma.io/docs/orm/overview/databases/neon
#
# Outro Postgres (Render, etc.) com muitas conexões:
# DATABASE_URL="postgresql://user:pass@host:5432/db?connection_limit=10&sslmode=require"

# JWT
JWT_SECRET="sua-chave-secreta-muito-segura-aqui"
JWT_EXPIRES_IN="7d"

# Redis (opcional para cache)
REDIS_URL="redis://localhost:6379"

# CORS (origens permitidas, separadas por vírgula)
CORS_ORIGIN="http://localhost:3000"

# Rate limiting (por IP) - valores em milissegundos
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
RATE_LIMIT_BLOCK_DURATION_MS=0

# Proxy/HTTPS: em produção, sirva a API atrás de proxy reverso (Nginx, Caddy, etc.) com HTTPS
# e defina TRUST_PROXY=true para que req.ip reflita o IP real do cliente (rate limit correto).
TRUST_PROXY=false

# Porta da API
PORT=3001

# URL pública do frontend (para links de validação de declarações)
APP_PUBLIC_URL=http://localhost:3000

# Integração INEP / APIs governamentais (opcional)
INEP_API_URL=https://api-publica.inep.gov.br
INEP_API_KEY=

# Produção: desativa rotas /api/dev/* (logs, blocklist). Use true ou NODE_ENV=production
DISABLE_DEV_ROUTES=false

# --- Migração falhou no Neon (P3009 / P3018)? ---
# 1) No arquivo .env (não este exemplo), defina DATABASE_URL com a URI do Neon (Direct recomendado).
# 2) No PowerShell, pasta já deve ser ...\armazena_historico\backend — NÃO rode "cd backend" de novo.
# 3) Comandos:
#    npx prisma migrate resolve --rolled-back "20260306040514_add_atestado_image_url"
#    npx prisma migrate deploy
# Alternativa sem editar .env: $env:DATABASE_URL="postgresql://...@ep-....neon.tech/neondb?sslmode=require"
